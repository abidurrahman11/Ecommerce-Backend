{
  "info": {
    "name": "E-commerce Ordering & Payment System",
    "description": "Backend API for user management, product catalog, orders, and multi-provider payments (Stripe, bKash). Import this, set the `base_url` variable, and run Auth > Login first to populate `token`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "admin_token", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "product_id", "value": "" },
    { "key": "category_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login (as admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.token) { pm.collectionVariables.set('admin_token', data.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@ecommerce.test\",\n  \"password\": \"Admin@12345\"\n}" }
          }
        },
        {
          "name": "Login (as regular user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.token) { pm.collectionVariables.set('token', data.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Get logged in user (/me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories (public)",
          "request": { "method": "GET", "url": "{{base_url}}/api/categories" }
        },
        {
          "name": "Category tree (public, DFS + cached)",
          "request": { "method": "GET", "url": "{{base_url}}/api/categories/tree" }
        },
        {
          "name": "Create category (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/api/categories",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Home Appliances\",\n  \"parent_id\": null\n}" }
          }
        },
        {
          "name": "Update category (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/api/categories/{{category_id}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Renamed Category\"\n}" }
          }
        },
        {
          "name": "Delete category (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/api/categories/{{category_id}}"
          }
        }
      ]
    },
    {
      "name": "Products (Public)",
      "item": [
        {
          "name": "List products",
          "request": { "method": "GET", "url": "{{base_url}}/api/products?page=1&limit=20" }
        },
        {
          "name": "Product detail",
          "request": { "method": "GET", "url": "{{base_url}}/api/products/{{product_id}}" }
        },
        {
          "name": "Related products (DFS recommendation)",
          "request": { "method": "GET", "url": "{{base_url}}/api/products/{{product_id}}/related" }
        }
      ]
    },
    {
      "name": "Products (Admin)",
      "item": [
        {
          "name": "List all products (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/api/admin/products"
          }
        },
        {
          "name": "Create product (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.id) { pm.collectionVariables.set('product_id', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/api/admin/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Blender\",\n  \"sku\": \"BLD-001\",\n  \"description\": \"A test product\",\n  \"price\": 49.99,\n  \"stock\": 20,\n  \"status\": \"active\",\n  \"category_id\": {{category_id}}\n}"
            }
          }
        },
        {
          "name": "Update product (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/api/admin/products/{{product_id}}",
            "body": { "mode": "raw", "raw": "{\n  \"price\": 59.99\n}" }
          }
        },
        {
          "name": "Delete product (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/api/admin/products/{{product_id}}"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.id) { pm.collectionVariables.set('order_id', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"product_id\": {{product_id}}, \"quantity\": 2 }\n  ]\n}"
            }
          }
        },
        {
          "name": "List my orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/orders"
          }
        },
        {
          "name": "Get order detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/orders/{{order_id}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Initiate payment (Stripe)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/payments/{{order_id}}/initiate",
            "body": { "mode": "raw", "raw": "{\n  \"provider\": \"stripe\"\n}" }
          }
        },
        {
          "name": "Initiate payment (bKash)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/payments/{{order_id}}/initiate",
            "body": { "mode": "raw", "raw": "{\n  \"provider\": \"bkash\"\n}" }
          }
        },
        {
          "name": "Confirm Stripe payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/payments/stripe/confirm",
            "body": { "mode": "raw", "raw": "{\n  \"payment_intent_id\": \"pi_xxx\"\n}" }
          }
        },
        {
          "name": "Execute bKash payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/payments/bkash/execute",
            "body": { "mode": "raw", "raw": "{\n  \"paymentID\": \"TR0011xxx\"\n}" }
          }
        },
        {
          "name": "Query bKash payment status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/payments/bkash/query/TR0011xxx"
          }
        },
        {
          "name": "List payments for an order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/payments/order/{{order_id}}"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        { "name": "Health check", "request": { "method": "GET", "url": "{{base_url}}/health" } }
      ]
    }
  ]
}
